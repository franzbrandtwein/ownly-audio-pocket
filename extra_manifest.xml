<!--
    Service declaration injected via buildozer's
        android.extra_manifest_xml = extra_manifest.xml
    The placeholder {{ args.extra_manifest_xml }} sits *inside* the
    <application> tag in p4a's manifest template, so this <service>
    element ends up exactly where it needs to live.

    android:process=":audio"   → runs in a dedicated OS process so the
                                  freezer cgroup of the activity process
                                  does NOT pause ExoPlayer.
    foregroundServiceType      → Android 14+ enforces a type for FGS;
                                  mediaPlayback gives the strongest
                                  background-protection guarantee.
-->
<service
    android:name="de.ownly.ownlyaudiopocket.ForegroundAudioService"
    android:foregroundServiceType="mediaPlayback"
    android:process=":audio"
    android:exported="false" />
